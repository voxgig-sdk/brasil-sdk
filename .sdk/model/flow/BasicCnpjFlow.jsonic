      input: {
        ref: "cnpj_ref01",
        srcdatavar: "cnpj_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "cnpj01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-cnpj_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicCnpjFlow"
}