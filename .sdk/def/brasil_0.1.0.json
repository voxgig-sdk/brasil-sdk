{
  "openapi": "3.0.3",
  "info": {
    "title": "Brasil API",
    "description": "Acesso programático de informações relacionadas a CEPs, bancos, CNPJ, IBGE, feriados nacionais, tabela FIPE e muito mais, fornecendo endpoints modernos com baixa latência. Este projeto busca centralizar dados públicos para uma fácil e rápida consulta em aplicações.",
    "version": "1.0.0",
    "contact": {
      "name": "Brasil API",
      "url": "https://brasilapi.com.br/docs"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "https://brasilapi.com.br/api",
      "description": "Production server"
    }
  ],
  "paths": {
    "/cep/v1/{cep}": {
      "get": {
        "summary": "Buscar informações de CEP",
        "description": "Retorna informações sobre o CEP informado, incluindo endereço, cidade, estado e coordenadas.",
        "operationId": "getCep",
        "tags": [
          "CEP"
        ],
        "parameters": [
          {
            "name": "cep",
            "in": "path",
            "description": "CEP a ser consultado (apenas números)",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9]{8}$",
              "example": "01310100"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CEP encontrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CEP"
                }
              }
            }
          },
          "404": {
            "description": "CEP não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/cep/v2/{cep}": {
      "get": {
        "summary": "Buscar informações de CEP (v2)",
        "description": "Versão 2 da API de CEP com dados adicionais e melhor performance.",
        "operationId": "getCepV2",
        "tags": [
          "CEP"
        ],
        "parameters": [
          {
            "name": "cep",
            "in": "path",
            "description": "CEP a ser consultado (apenas números)",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9]{8}$",
              "example": "01310100"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CEP encontrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CEP"
                }
              }
            }
          },
          "404": {
            "description": "CEP não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/banks/v1": {
      "get": {
        "summary": "Lista todos os bancos",
        "description": "Retorna uma lista com informações de todos os bancos do Brasil.",
        "operationId": "getBanks",
        "tags": [
          "Bancos"
        ],
        "responses": {
          "200": {
            "description": "Lista de bancos retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Bank"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/banks/v1/{code}": {
      "get": {
        "summary": "Buscar banco por código",
        "description": "Retorna informações sobre um banco específico através do seu código.",
        "operationId": "getBankByCode",
        "tags": [
          "Bancos"
        ],
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "description": "Código do banco (3 dígitos)",
            "required": true,
            "schema": {
              "type": "string",
              "example": "001"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Banco encontrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bank"
                }
              }
            }
          },
          "404": {
            "description": "Banco não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/cnpj/v1/{cnpj}": {
      "get": {
        "summary": "Buscar informações de CNPJ",
        "description": "Retorna informações detalhadas sobre o CNPJ informado.",
        "operationId": "getCnpj",
        "tags": [
          "CNPJ"
        ],
        "parameters": [
          {
            "name": "cnpj",
            "in": "path",
            "description": "CNPJ a ser consultado (apenas números)",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9]{14}$",
              "example": "00000000000191"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CNPJ encontrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CNPJ"
                }
              }
            }
          },
          "404": {
            "description": "CNPJ não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/feriados/v1/{ano}": {
      "get": {
        "summary": "Lista feriados nacionais",
        "description": "Retorna a lista de feriados nacionais para um determinado ano.",
        "operationId": "getFeriados",
        "tags": [
          "Feriados"
        ],
        "parameters": [
          {
            "name": "ano",
            "in": "path",
            "description": "Ano a ser consultado",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1900,
              "maximum": 2100,
              "example": 2024
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de feriados retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Feriado"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fipe/marcas/v1/{tipoVeiculo}": {
      "get": {
        "summary": "Lista marcas de veículos",
        "description": "Retorna a lista de marcas disponíveis na tabela FIPE para um tipo de veículo.",
        "operationId": "getFipeMarcas",
        "tags": [
          "FIPE"
        ],
        "parameters": [
          {
            "name": "tipoVeiculo",
            "in": "path",
            "description": "Tipo de veículo (carros, motos ou caminhoes)",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "carros",
                "motos",
                "caminhoes"
              ],
              "example": "carros"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de marcas retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FipeMarca"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fipe/preco/v1/{codigoFipe}": {
      "get": {
        "summary": "Buscar preço pela tabela FIPE",
        "description": "Retorna o preço de um veículo específico através do código FIPE.",
        "operationId": "getFipePreco",
        "tags": [
          "FIPE"
        ],
        "parameters": [
          {
            "name": "codigoFipe",
            "in": "path",
            "description": "Código FIPE do veículo",
            "required": true,
            "schema": {
              "type": "string",
              "example": "001004-1"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Preço encontrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FipePreco"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Código FIPE não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/ibge/municipios/v1/{siglaUF}": {
      "get": {
        "summary": "Lista municípios por UF",
        "description": "Retorna a lista de municípios de uma determinada UF.",
        "operationId": "getIbgeMunicipios",
        "tags": [
          "IBGE"
        ],
        "parameters": [
          {
            "name": "siglaUF",
            "in": "path",
            "description": "Sigla da UF (2 caracteres)",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "example": "SP"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de municípios retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Municipio"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ibge/uf/v1": {
      "get": {
        "summary": "Lista todas as UFs",
        "description": "Retorna informações sobre todas as Unidades Federativas do Brasil.",
        "operationId": "getIbgeUFs",
        "tags": [
          "IBGE"
        ],
        "responses": {
          "200": {
            "description": "Lista de UFs retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UF"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ibge/uf/v1/{siglaUF}": {
      "get": {
        "summary": "Buscar informações de uma UF",
        "description": "Retorna informações detalhadas sobre uma Unidade Federativa específica.",
        "operationId": "getIbgeUF",
        "tags": [
          "IBGE"
        ],
        "parameters": [
          {
            "name": "siglaUF",
            "in": "path",
            "description": "Sigla da UF (2 caracteres)",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "example": "SP"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "UF encontrada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UF"
                }
              }
            }
          },
          "404": {
            "description": "UF não encontrada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/ddd/v1/{ddd}": {
      "get": {
        "summary": "Buscar informações por DDD",
        "description": "Retorna informações sobre cidades por código DDD.",
        "operationId": "getDDD",
        "tags": [
          "DDD"
        ],
        "parameters": [
          {
            "name": "ddd",
            "in": "path",
            "description": "Código DDD (2 dígitos)",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9]{2}$",
              "example": "11"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "DDD encontrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DDD"
                }
              }
            }
          },
          "404": {
            "description": "DDD não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CEP": {
        "type": "object",
        "properties": {
          "cep": {
            "type": "string",
            "description": "CEP consultado",
            "example": "01310100"
          },
          "state": {
            "type": "string",
            "description": "Sigla do estado",
            "example": "SP"
          },
          "city": {
            "type": "string",
            "description": "Nome da cidade",
            "example": "São Paulo"
          },
          "neighborhood": {
            "type": "string",
            "description": "Nome do bairro",
            "example": "Bela Vista"
          },
          "street": {
            "type": "string",
            "description": "Nome da rua",
            "example": "Avenida Paulista"
          },
          "service": {
            "type": "string",
            "description": "Serviço utilizado para consulta",
            "example": "viacep"
          },
          "location": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "example": "Point"
              },
              "coordinates": {
                "type": "object",
                "properties": {
                  "longitude": {
                    "type": "string",
                    "example": "-46.6527128"
                  },
                  "latitude": {
                    "type": "string",
                    "example": "-23.5629358"
                  }
                }
              }
            }
          }
        }
      },
      "Bank": {
        "type": "object",
        "properties": {
          "ispb": {
            "type": "string",
            "description": "Identificador único do banco",
            "example": "00000000"
          },
          "name": {
            "type": "string",
            "description": "Nome do banco",
            "example": "Banco do Brasil S.A."
          },
          "code": {
            "type": "integer",
            "description": "Código do banco",
            "example": 1
          },
          "fullName": {
            "type": "string",
            "description": "Nome completo do banco",
            "example": "Banco do Brasil S.A."
          }
        }
      },
      "CNPJ": {
        "type": "object",
        "properties": {
          "cnpj": {
            "type": "string",
            "description": "CNPJ consultado",
            "example": "00000000000191"
          },
          "razao_social": {
            "type": "string",
            "description": "Razão social da empresa",
            "example": "BANCO DO BRASIL S.A."
          },
          "nome_fantasia": {
            "type": "string",
            "description": "Nome fantasia da empresa",
            "example": "BANCO DO BRASIL"
          },
          "cnae_fiscal": {
            "type": "integer",
            "description": "CNAE fiscal principal"
          },
          "cnae_fiscal_descricao": {
            "type": "string",
            "description": "Descrição do CNAE fiscal"
          },
          "data_inicio_atividade": {
            "type": "string",
            "format": "date",
            "description": "Data de início das atividades"
          },
          "natureza_juridica": {
            "type": "string",
            "description": "Código da natureza jurídica"
          },
          "logradouro": {
            "type": "string",
            "description": "Logradouro do endereço"
          },
          "numero": {
            "type": "string",
            "description": "Número do endereço"
          },
          "complemento": {
            "type": "string",
            "description": "Complemento do endereço"
          },
          "bairro": {
            "type": "string",
            "description": "Bairro"
          },
          "cep": {
            "type": "string",
            "description": "CEP"
          },
          "uf": {
            "type": "string",
            "description": "UF"
          },
          "municipio": {
            "type": "string",
            "description": "Município"
          },
          "ddd_telefone_1": {
            "type": "string",
            "description": "Telefone principal"
          },
          "capital_social": {
            "type": "number",
            "description": "Capital social da empresa"
          },
          "porte": {
            "type": "string",
            "description": "Porte da empresa"
          },
          "qsa": {
            "type": "array",
            "description": "Quadro de sócios e administradores",
            "items": {
              "type": "object",
              "properties": {
                "nome": {
                  "type": "string"
                },
                "qual": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Feriado": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "description": "Data do feriado",
            "example": "2024-01-01"
          },
          "name": {
            "type": "string",
            "description": "Nome do feriado",
            "example": "Ano Novo"
          },
          "type": {
            "type": "string",
            "description": "Tipo de feriado",
            "example": "national"
          }
        }
      },
      "FipeMarca": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "description": "Nome da marca",
            "example": "Fiat"
          },
          "valor": {
            "type": "string",
            "description": "Código da marca",
            "example": "21"
          }
        }
      },
      "FipePreco": {
        "type": "object",
        "properties": {
          "valor": {
            "type": "string",
            "description": "Valor do veículo",
            "example": "R$ 50.000,00"
          },
          "marca": {
            "type": "string",
            "description": "Marca do veículo",
            "example": "Fiat"
          },
          "modelo": {
            "type": "string",
            "description": "Modelo do veículo",
            "example": "Palio 1.0"
          },
          "anoModelo": {
            "type": "integer",
            "description": "Ano do modelo",
            "example": 2020
          },
          "combustivel": {
            "type": "string",
            "description": "Tipo de combustível",
            "example": "Gasolina"
          },
          "codigoFipe": {
            "type": "string",
            "description": "Código FIPE",
            "example": "001004-1"
          },
          "mesReferencia": {
            "type": "string",
            "description": "Mês de referência da tabela",
            "example": "janeiro de 2024"
          },
          "tipoVeiculo": {
            "type": "integer",
            "description": "Tipo do veículo",
            "example": 1
          },
          "siglaCombustivel": {
            "type": "string",
            "description": "Sigla do combustível",
            "example": "G"
          }
        }
      },
      "Municipio": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "description": "Nome do município",
            "example": "São Paulo"
          },
          "codigo_ibge": {
            "type": "string",
            "description": "Código IBGE do município",
            "example": "3550308"
          }
        }
      },
      "UF": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "ID da UF",
            "example": 35
          },
          "sigla": {
            "type": "string",
            "description": "Sigla da UF",
            "example": "SP"
          },
          "nome": {
            "type": "string",
            "description": "Nome da UF",
            "example": "São Paulo"
          },
          "regiao": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 3
              },
              "sigla": {
                "type": "string",
                "example": "SE"
              },
              "nome": {
                "type": "string",
                "example": "Sudeste"
              }
            }
          }
        }
      },
      "DDD": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "description": "Sigla do estado",
            "example": "SP"
          },
          "cities": {
            "type": "array",
            "description": "Lista de cidades com este DDD",
            "items": {
              "type": "string"
            },
            "example": [
              "São Paulo",
              "Guarulhos",
              "Osasco"
            ]
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Nome do erro",
            "example": "NotFoundError"
          },
          "message": {
            "type": "string",
            "description": "Mensagem de erro",
            "example": "Recurso não encontrado"
          },
          "type": {
            "type": "string",
            "description": "Tipo do erro",
            "example": "not_found"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "CEP",
      "description": "Operações relacionadas a consulta de CEPs"
    },
    {
      "name": "Bancos",
      "description": "Informações sobre bancos brasileiros"
    },
    {
      "name": "CNPJ",
      "description": "Consulta de informações de CNPJ"
    },
    {
      "name": "Feriados",
      "description": "Feriados nacionais brasileiros"
    },
    {
      "name": "FIPE",
      "description": "Tabela FIPE de preços de veículos"
    },
    {
      "name": "IBGE",
      "description": "Dados do IBGE sobre municípios e UFs"
    },
    {
      "name": "DDD",
      "description": "Informações sobre códigos DDD"
    }
  ]
}
